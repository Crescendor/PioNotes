{
  "manifest_version": 3,
  "name": "PioNotes - Hızlı Not & Kopyala",
  "version": "1.0.0",
  "description": "Ekranın sağında açılan dikey panelde notlarınızı düzenleyin, klasörleyin, PioNotes ile tek tıkla kopyalayın.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "PioNotes'u Aç",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "MacCtrl+Shift+Y"
      },
      "description": "PioNotes Yan Panelini Aç/Kapat"
    }
  }
}
